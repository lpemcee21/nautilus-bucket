{
  "version": "1.5.0",
  "description": "Axis - Rank anything. Import, share, and get started.",
  "homepage": "https://github.com/PR0Gorib/Axis",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/PR0Gorib/Axis/releases/download/v1.5.0/Axis_1.5.0_x64_en-US.msi",
      "hash": "2BCB5FC2A7E07A6F42B90AC137CB26EC56441A8450766BE3DE29B0FD6AA35344"
    }
  },
"installer": {
  "script": [
    "$msi = Get-ChildItem \"$dir\\*.msi\" | Select-Object -First 1",
    "if (-not $msi) { throw \"No MSI found in $dir\" }",
    "Expand-MsiArchive \"$dir\\$($msi.Name)\" -DestinationPath \"$dir\\extracted\"",
    "$exe = Get-ChildItem \"$dir\\extracted\\**\\Axis.exe\" -Recurse | Select-Object -First 1",
    "if (-not $exe) { throw \"Axis.exe not found in extracted MSI\" }",
    "Move-Item \"$exe.FullName\" \"$dir\\Axis.exe\"",
    "Remove-Item \"$dir\\extracted\" -Recurse -Force",
    "Remove-Item \"$dir\\*.msi\" -Force"
  ]
},
  "bin": "Axis.exe",
  "shortcuts": [
    [
      "Axis.exe",
      "Axis"
    ]
  ],
  "checkver": {
    "github": "PR0Gorib/Axis",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/PR0Gorib/Axis/releases/download/v$version/Axis_$version_x64_en-US.msi"
      }
    }
  }
}
